# ── Staging environment ────────────────────────────────────────────────────────
# Copy to .env.staging and fill in values before running docker compose

NODE_ENV=development
PORT=5001

# Postgres — matches docker-compose.staging.yml db service
DB_PASSWORD=hcrm_staging
DATABASE_URL=postgresql://hcrm:hcrm_staging@db:5432/hcrm_staging

# Session
SESSION_SECRET=change_me_staging_secret_32_chars_min

# Optional: SMTP for email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@rgbindia.com

# Optional: SSL for DB (false inside Docker)
DATABASE_SSL=false
