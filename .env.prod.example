# ── Production environment ─────────────────────────────────────────────────────
# Copy to .env.prod and fill in values before running docker compose

NODE_ENV=production
PORT=5001

# Postgres — matches docker-compose.prod.yml db service
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://hcrm:CHANGE_ME_STRONG_PASSWORD@db:5432/hcrm_production

# Session — use a long random string (openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME_PRODUCTION_SECRET

# SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@rgbindia.com

# SSL for DB (false inside Docker, true if using external managed Postgres)
DATABASE_SSL=false
